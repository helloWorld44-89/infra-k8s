{
  "title": "Homelab Infrastructure Overview",
  "uid": "homelab-overview",
  "tags": ["homelab", "infrastructure", "overview"],
  "timezone": "browser",
  "schemaVersion": 16,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "Node Health Overview",
      "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}
    },
    {
      "id": 2,
      "title": "CPU Usage per Node",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 1},
      "targets": [
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 90}
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Memory Usage per Node",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 1},
      "targets": [
        {
          "expr": "(node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / node_memory_MemTotal_bytes * 100",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 90}
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Disk Usage per Node",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 7, "w": 24, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "(node_filesystem_size_bytes{fstype!~\"tmpfs|overlay\"} - node_filesystem_avail_bytes{fstype!~\"tmpfs|overlay\"}) / node_filesystem_size_bytes{fstype!~\"tmpfs|overlay\"} * 100",
          "legendFormat": "{{instance}} {{mountpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": 0},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 90}
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Pod Health",
      "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 15}
    },
    {
      "id": 6,
      "title": "Running Pods",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 8, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "count(kube_pod_status_phase{phase=\"Running\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        }
      }
    },
    {
      "id": 7,
      "title": "Pending Pods",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 8, "x": 8, "y": 16},
      "targets": [
        {
          "expr": "sum(kube_pod_status_phase{phase=\"Pending\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": 0},
              {"color": "red", "value": 1}
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "title": "CrashLooping Pods",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 8, "x": 16, "y": 16},
      "targets": [
        {
          "expr": "sum(kube_pod_container_status_restarts_total) by (namespace, pod)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "green", "value": 0},
              {"color": "red", "value": 1}
            ]
          }
        }
      }
    },
    {
      "id": 9,
      "title": "Cluster Resource Utilization",
      "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 20}
    },
    {
      "id": 10,
      "title": "CPU Allocated vs Total",
      "type": "barchart",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 21},
      "targets": [
        {
          "expr": "sum(kube_node_status_capacity{resource=\"cpu\"})",
          "legendFormat": "Total CPU",
          "refId": "A"
        },
        {
          "expr": "sum(kube_node_status_allocatable{resource=\"cpu\"})",
          "legendFormat": "Allocatable CPU",
          "refId": "B"
        }
      ]
    },
    {
      "id": 11,
      "title": "Memory Allocated vs Total",
      "type": "barchart",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 21},
      "targets": [
        {
          "expr": "sum(kube_node_status_capacity{resource=\"memory\"})",
          "legendFormat": "Total Memory",
          "refId": "A"
        },
        {
          "expr": "sum(kube_node_status_allocatable{resource=\"memory\"})",
          "legendFormat": "Allocatable Memory",
          "refId": "B"
        }
      ]
    },
    {
      "id": 12,
      "title": "Kubernetes Control Plane",
      "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 28}
    },
    {
      "id": 13,
      "title": "API Server Status",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 8, "x": 0, "y": 29},
      "targets": [
        {
          "expr": "up{job=\"kubernetes-apiservers\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "red", "value": 0},
              {"color": "green", "value": 1}
            ]
          }
        }
      }
    },
    {
      "id": 14,
      "title": "CoreDNS Status",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 8, "x": 8, "y": 29},
      "targets": [
        {
          "expr": "kube_deployment_status_replicas_available{namespace=\"kube-system\", deployment=\"coredns\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "red", "value": 0},
              {"color": "green", "value": 1}
            ]
          }
        }
      }
    },
    {
      "id": 15,
      "title": "Nodes Ready",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 8, "x": 16, "y": 29},
      "targets": [
        {
          "expr": "count(kube_node_status_condition{condition=\"Ready\", status=\"true\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "red", "value": 0},
              {"color": "yellow", "value": 1},
              {"color": "green", "value": 3}
            ]
          }
        }
      }
    },
    {
      "id": 16,
      "title": "Flux CD Pipeline",
      "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 33}
    },
    {
      "id": 17,
      "title": "Flux Source Status",
      "type": "table",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 34},
      "targets": [
        {
          "expr": "flux_source_status_ready",
          "refId": "A"
        }
      ]
    },
    {
      "id": 18,
      "title": "Flux Sync Status",
      "type": "table",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 34},
      "targets": [
        {
          "expr": "flux_controller_sync_total",
          "refId": "A"
        }
      ]
    },
    {
      "id": 19,
      "title": "Network Throughput",
      "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 41}
    },
    {
      "id": 20,
      "title": "Network I/O per Node",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 7, "w": 24, "x": 0, "y": 42},
      "targets": [
        {
          "expr": "rate(node_network_transmit_bytes_total[5m])",
          "legendFormat": "{{instance}} TX",
          "refId": "A"
        },
        {
          "expr": "rate(node_network_receive_bytes_total[5m])",
          "legendFormat": "{{instance}} RX",
          "refId": "B"
        }
      ]
    },
    {
      "id": 21,
      "title": "Top Resource Consumers",
      "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 49}
    },
    {
      "id": 22,
      "title": "Top 5 CPU Consuming Pods",
      "type": "table",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 50},
      "targets": [
        {
          "expr": "topk(5, sum(rate(container_cpu_usage_seconds_total{container!~\"POD|pause.*\"}[5m])) by (pod, namespace))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 23,
      "title": "Top 5 Memory Consuming Pods",
      "type": "table",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 50},
      "targets": [
        {
          "expr": "topk(5, sum(container_memory_working_set_bytes{container!~\"POD|pause.*\"}) by (pod, namespace))",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  }
}
